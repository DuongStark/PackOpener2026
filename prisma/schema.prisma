// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Rarity {
  Common
  Rare
  Epic
  Legendary
}

enum Role {
  USER
  ADMIN
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String      @map("password_hash")
  username     String      @unique
  balance      Int         @default(1000)
  role         Role        @default(USER)
  isActive     Boolean     @default(true) @map("is_active")
  deletedAt    DateTime?   @map("deleted_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  userPacks    UserPack[]
  inventories  Inventory[]

  @@map("users")
}

model Cards {
  id                 String              @id @default(uuid())
  sofifaId           Int                 @unique @map("sofifa_id")
  name               String
  overall            Int
  rarity             Rarity
  position           String
  club               String?
  nation             String?
  imageUrl           String?             @map("image_url")
  sellPrice          Int                 @default(10) @map("sell_price")
  pace               Int?
  shooting           Int?
  passing            Int?
  dribbling          Int?
  defending          Int?
  physical           Int?
  createdAt          DateTime            @default(now()) @map("created_at")
  packCardPools      PackCardPool[]
  packOpeningResults PackOpeningResult[]
  inventories        Inventory[]

  @@map("cards")
}

model PackDefinition {
  id            String         @id @default(uuid())
  name          String
  description   String?
  price         Int
  cardCount     Int            @map("card_count")
  imageUrl      String?        @map("image_url")
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  packCardPools PackCardPool[]
  userPacks     UserPack[]

  @@map("pack_definitions")
}

model PackCardPool {
  id     String         @id @default(uuid())
  packId String         @map("pack_id") @db.Uuid
  cardId String         @map("card_id") @db.Uuid
  weight Int            @default(1)
  pack   PackDefinition @relation(fields: [packId], references: [id], onDelete: Cascade)
  card   Cards          @relation(fields: [cardId], references: [id], onDelete: Restrict)

  @@unique([packId, cardId])
}

model UserPack {
  id                 String              @id @default(uuid())
  userId             String              @map("user_id") @db.Uuid
  packId             String              @map("pack_id") @db.Uuid
  status             String              @default("pending")
  purchasedAt        DateTime            @default(now()) @map("purchased_at")
  openedAt           DateTime?           @map("opened_at")
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  pack               PackDefinition      @relation(fields: [packId], references: [id], onDelete: Restrict)
  packOpeningResults PackOpeningResult[]
}

model PackOpeningResult {
  id             String   @id @default(uuid())
  userPackId     String   @map("user_pack_id") @db.Uuid
  cardId         String   @map("card_id") @db.Uuid
  cardSnapshot   Json     @map("card_snapshot")
  positionInPack Int      @map("position_in_pack")
  createdAt      DateTime @default(now()) @map("created_at")
  userPack       UserPack @relation(fields: [userPackId], references: [id], onDelete: Cascade)
  card           Cards    @relation(fields: [cardId], references: [id], onDelete: Restrict)
}

model Inventory {
  id       String @id @default(uuid())
  userId   String @map("user_id") @db.Uuid
  cardId   String @map("card_id") @db.Uuid
  quantity Int    @default(1)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  card     Cards  @relation(fields: [cardId], references: [id], onDelete: Restrict)

  @@unique([userId, cardId])
}
